DATABASE_URL=postgresql+asyncpg://shortener_app:localdev@localhost:5432/shortener
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
ENVIRONMENT=development

# To run WITHOUT Clerk auth (dev bypass), leave the keys as sk_test_... / pk_test_...
# To run WITH Clerk auth locally, replace with real keys from https://dashboard.clerk.com

# Email — default: mailpit (local SMTP, web UI at http://localhost:8025)
# Switch to "resend" for production and set RESEND_API_KEY
EMAIL_PROVIDER=mailpit
RESEND_API_KEY=
EMAIL_FROM=Snip <noreply@snip.dev>
SMTP_HOST=localhost
SMTP_PORT=1025
CLICK_THRESHOLD=100
