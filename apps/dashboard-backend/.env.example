DATABASE_URL=postgresql+asyncpg://shortener_app:localdev@localhost:5432/shortener

CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

ENVIRONMENT=development

# Email — default: mailpit (local SMTP, web UI at http://localhost:8025)
# Switch to "resend" for production and set RESEND_API_KEY
EMAIL_PROVIDER=mailpit
RESEND_API_KEY=
EMAIL_FROM=Snip <noreply@snip.dev>
SMTP_HOST=localhost
SMTP_PORT=1025
CLICK_THRESHOLD=100

# Storage (MinIO local dev — S3 API on 9002 due to port 9000 conflict)
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=localhost:9002
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
OG_IMAGE_BUCKET=snip-og-images
OG_IMAGE_PUBLIC_URL_BASE=http://localhost:9002/snip-og-images
REDIRECT_BASE_URL=http://localhost:8001
