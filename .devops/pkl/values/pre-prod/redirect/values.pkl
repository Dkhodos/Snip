/// Redirect service config for pre-prod.

queue_provider = "gcp_pubsub"
click_topic = "click-events-pre-prod"

// OG image meta tags served to social crawlers
og_image_base_url = "https://storage.googleapis.com/snip-og-images-pre-prod"

redirect_base_url = "https://r.pre-prod.snip-app.win"

// OpenTelemetry
otel_service_name = "redirect-service"
otel_enable_fastapi = "true"
otel_enable_sqlalchemy = "true"
otel_enable_httpx = "false"
otel_enable_grpc = "true"
