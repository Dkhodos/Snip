/// Backend secrets for pre-prod.
/// Values are managed manually in GCP Secret Manager.
/// secret_name is the base — Terraform appends "-{env}" automatically.
amends "../../../schemas/Secrets.pkl"

secrets {
  new {
    key = "database_url"
    env_var = "DATABASE_URL"
    secret_name = "snip-database-url"
  }
  new {
    key = "clerk_secret"
    env_var = "CLERK_SECRET_KEY"
    secret_name = "snip-clerk-secret"
  }
  new {
    key = "resend_api_key"
    env_var = "RESEND_API_KEY"
    secret_name = "snip-resend-api-key"
  }
}
