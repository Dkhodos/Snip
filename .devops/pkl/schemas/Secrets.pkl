/// Secret declaration file.
/// These files declare WHAT secrets must exist in GCP Secret Manager.
/// Actual values are set manually via `gcloud secrets versions add`.
/// Terraform creates the Secret Manager shells from these declarations.

// A single secret declaration.
class SecretEntry {
  /// Internal key name (snake_case).
  key: String(matches(Regex(#"^[a-z][a-z0-9_]*$"#)))

  /// Environment variable name injected into Cloud Run (UPPER_SNAKE_CASE).
  /// Optional for global secrets that are not injected into services.
  env_var: (String(matches(Regex(#"^[A-Z][A-Z0-9_]*$"#))))?

  /// GCP Secret Manager name (kebab-case, snip- prefix).
  /// Terraform appends "-{env}" automatically for env-specific secrets.
  secret_name: String(matches(Regex(#"^snip-[a-z0-9-]+$"#)))
}

/// List of secret declarations for this scope.
secrets: Listing<SecretEntry>
